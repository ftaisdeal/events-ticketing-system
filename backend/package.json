{
  "name": "ticketing-backend",
  "version": "1.0.0",
  "description": "Backend API for events ticketing system",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx watch server.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "migrate": "sequelize-cli db:migrate",
    "migrate:undo": "sequelize-cli db:migrate:undo",
    "test": "jest"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "express-validator": "^7.2.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.29.4",
    "morgan": "^1.10.0",
    "mysql2": "^3.15.2",
    "nodemailer": "^7.0.9",
    "qrcode": "^1.5.3",
  "sequelize": "^6.37.7",
    "stripe": "^13.6.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.13.10",
    "jest": "^29.6.2",
    "nodemon": "^3.0.1",
    "sequelize-cli": "^6.6.1",
    "supertest": "^7.1.4",
    "tsx": "^4.20.5",
    "typescript": "^5.8.2"
  },
  "keywords": [
    "ticketing",
    "events",
    "nodejs",
    "express",
    "mysql"
  ],
