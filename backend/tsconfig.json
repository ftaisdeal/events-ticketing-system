{
  "compilerOptions": {
    "target": "ES2020",
    "module": "nodenext",
    "ignoreDeprecations": "6.0",
    "rootDir": ".",
    "outDir": "dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
